o Bring\"/><meta property=\"og:description\" content=\"一份方便的必需品清单供您打包\"/><meta property=\"og:image:type\" content=\"image/jpeg\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image\" content=\"https://docstemplate.vercel.app/opengraph-image.jpg?1f4cd24de62e2382\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"需要携带的物品 - What to Bring\"/><meta name=\"twitter:description\" content=\"一份方便的必需品清单供您打包\"/><meta name=\"twitter:image:type\" content=\"image/jpeg\"/><meta name=\"twitter:image:width\" content=\"1200\"/><meta name=\"twitter:image:height\" content=\"630\"/><meta name=\"twitter:image\" content=\"https://docstemplate.vercel.app/opengraph-image.jpg?1f4cd24de62e2382\"/><link rel=\"icon\" href=\"/favicon.ico\" type=\"image/x-icon\" sizes=\"48x48\"/><meta name=\"next-size-adjust\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"__variable_3a0388 __variable_c1e5c9 font-regular\"><script>!function(){try{var d=document.documentElement,c=d.classList;c.remove('light','dark');var e=localStorage.getItem('theme');if('system'===e||(!e&&true)){var t='(prefers-color-scheme: dark)',m=window.matchMedia(t);if(m.media!==t||m.matches){d.style.colorScheme = 'dark';c.add('dark')}else{d.style.colorScheme = 'light';c.add('light')}}else if(e){c.add(e|| '')}if(e==='light'||e==='dark')d.style.colorScheme=e}catch(e){}}()</script><nav class=\"w-full border-b h-16 sticky top-0 z-50 lg:px-4 px-2 backdrop-filter backdrop-blur-xl bg-opacity-5\"><div class=\"sm:p-3 p-2 max-w-[1530px] mx-auto h-full flex items-center justify-between gap-2\"><div class=\"flex items-center gap-5\"><button class=\"items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-