---
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import { MobileNav } from '@/components/islands/MobileNav';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Rooms', href: '/rooms' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'About', href: '/about' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full border-b border-border/50 bg-background/70 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>Westholme Park</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-3 py-2 text-sm font-medium transition-colors rounded-md ${
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-foreground bg-muted'
              : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/contact"
        class="hidden bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition-opacity hover:opacity-90 md:inline-flex"
      >
        Check Availability
      </a>
      <ThemeToggle client:load />
      <MobileNav client:load links={navLinks} currentPath={currentPath} />
    </div>
  </div>
</header>
