---
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-b from-background/10 via-background/60 to-background z-10" />
    <div class="absolute inset-0 bg-gradient-to-r from-background/80 via-transparent to-background/80 z-10" />
    <img
      src="/images/hero/hero-1.jpg"
      alt="Westholme Park exterior"
      class="w-full h-full object-cover"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0 bg-primary/5 dark:bg-primary/10 z-0" />
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
    <div class="max-w-3xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl lg:text-7xl text-balance">
        A home designed for <span class="text-primary">female students</span> at UCLA
      </h1>
      <p class="mt-6 text-lg leading-8 text-muted-foreground max-w-2xl text-balance">
        Fully furnished shared and private bedrooms in a beautifully maintained property across from campus. Flexible leases, all utilities included.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/rooms"
          class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-sm hover:opacity-90 transition-opacity"
        >
          View Rooms & Pricing
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-lg border border-border bg-background px-6 py-3 text-sm font-semibold text-foreground shadow-sm hover:bg-muted transition-colors"
        >
          Schedule a Tour
        </a>
      </div>
    </div>
  </div>
</section>
