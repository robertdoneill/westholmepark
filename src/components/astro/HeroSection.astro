---
const imageBase = 'https://images.westholmepark.com';
---

<section class="relative min-h-screen overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/30 to-background z-10" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/35 to-transparent z-10" />
    <img
      src={`${imageBase}/courtyard-arches-seating.jpg`}
      alt="Westholme Park courtyard with arched entry and outdoor seating"
      class="w-full h-full object-cover"
    />
  </div>

  <div class="relative z-10 mx-auto flex min-h-screen max-w-7xl items-end px-4 pb-14 pt-28 sm:px-6 sm:pb-20 lg:px-8">
    <div class="max-w-4xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/80">Female student housing near UCLA</p>
      <h1 class="mt-4 max-w-3xl text-5xl font-extrabold tracking-tight text-white sm:text-6xl lg:text-7xl text-balance">
        Your UCLA home, already put together.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/85 sm:text-xl text-balance">
        Fully furnished rooms, welcoming shared spaces, and a calmer move-in experience for students who want comfort, community, and more time for campus life.
      </p>
      <div class="mt-8 flex flex-wrap gap-3 text-sm font-medium text-white/90">
        <span class="border border-white/25 bg-white/10 px-3 py-1.5 backdrop-blur">Walkable to UCLA</span>
        <span class="border border-white/25 bg-white/10 px-3 py-1.5 backdrop-blur">Fully furnished</span>
        <span class="border border-white/25 bg-white/10 px-3 py-1.5 backdrop-blur">Utilities included</span>
        <span class="border border-white/25 bg-white/10 px-3 py-1.5 backdrop-blur">Managed locally</span>
      </div>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-lg shadow-black/20 transition-opacity hover:opacity-90"
        >
          Check Availability
        </a>
        <a
          href="/gallery"
          class="inline-flex items-center justify-center border border-white/35 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition-colors hover:bg-white/20"
        >
          See the House
        </a>
      </div>
    </div>
  </div>
</section>
