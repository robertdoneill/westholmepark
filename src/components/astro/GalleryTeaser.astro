---
const images = [
  { src: '/images/common/living.jpg', alt: 'Living room' },
  { src: '/images/common/kitchen.jpg', alt: 'Kitchen' },
  { src: '/images/rooms/private/bedroom-1.jpg', alt: 'Private bedroom' },
  { src: '/images/common/outdoor.jpg', alt: 'Outdoor patio' },
];
---

<section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 reveal">
    <div>
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Take a look around</h2>
      <p class="mt-4 text-lg text-muted-foreground">Bright, modern spaces designed for comfort and focus.</p>
    </div>
    <a href="/gallery" class="inline-flex items-center text-sm font-semibold text-primary hover:underline">
      View full gallery
      <svg class="ml-1 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {images.map((img) => (
      <div class="group relative aspect-[4/3] overflow-hidden rounded-xl border border-border reveal">
        <img
          src={img.src}
          alt={img.alt}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          onerror="this.parentElement.classList.add('flex','items-center','justify-center','bg-muted');this.outerHTML='<span class=text-muted-foreground text-sm>Photo coming soon</span>'"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
        <span class="absolute bottom-3 left-3 text-sm font-medium text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          {img.alt}
        </span>
      </div>
    ))}
  </div>
</section>
