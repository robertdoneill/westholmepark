---
import Layout from '@/layouts/Layout.astro';
import { SvgFloorPlanViewer } from '@/components/islands/SvgFloorPlanViewer';
---

<Layout title="Floor Plans — Westholme Park" description="Explore rendered floor plans for Westholme Park student housing near UCLA.">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="max-w-3xl reveal">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Floor Plans</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">See how the house is laid out.</h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        Review each floor to understand room locations, nearby bathrooms, and the shared spaces that shape daily life in the house.
      </p>
    </div>

    <SvgFloorPlanViewer client:load />
  </div>
</Layout>
