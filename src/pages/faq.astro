---
import Layout from '@/layouts/Layout.astro';

const faqs = [
  {
    q: 'Who can apply to live at Westholme Park?',
    a: 'Westholme Park is open to female students attending UCLA, UCLA Extension, or Santa Monica College. We welcome both undergraduate and graduate students.',
  },
  {
    q: 'What do I need to apply?',
    a: 'You will need a valid passport, a U.S. visa or school/work authorization, and proof of funds. Proof of funds can be financial aid, student loans, a pay stub, an acceptance letter, or a bank statement showing sufficient funds to cover your stay.',
  },
  {
    q: 'Are utilities included?',
    a: 'Yes — electricity, gas, water, and high-speed fiber WiFi are all included in your monthly rent.',
  },
  {
    q: 'Can I choose my roommate?',
    a: 'If you are booking a shared room and already have a roommate in mind, let us know and we will do our best to place you together. Otherwise, we offer roommate matching based on lifestyle and study habits.',
  },
  {
    q: 'Is parking available?',
    a: 'Yes, off-street parking is available for an additional fee. Street parking is also available in the neighborhood.',
  },
  {
    q: 'How long is the lease?',
    a: 'We offer flexible lease terms. Most students sign for the academic year (September–June), but shorter and longer terms are available depending on room availability.',
  },
  {
    q: 'Is the building secure?',
    a: 'Absolutely. The property features keyless entry, security cameras in common areas, and a secure building entrance.',
  },
  {
    q: 'What should I bring?',
    a: 'Your room comes fully furnished with a bed, desk, and closet. You should bring bedding (twin XL for standard rooms), personal items, and anything that makes it feel like home. See our docs for a full packing list.',
  },
  {
    q: 'How do I schedule a tour?',
    a: 'You can book a virtual or in-person tour through our online calendar. Tours are available in English.',
  },
  {
    q: 'What is the move-out process?',
    a: 'Move-out notices must be submitted through the RentVine resident portal at least 30 days before your intended move-out date. Final walkthroughs are scheduled at the end of each month.',
  },
];
---

<Layout title="FAQ — Westholme Park" description="Frequently asked questions about living at Westholme Park.">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="text-center reveal">
      <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">Frequently Asked Questions</h1>
      <p class="mt-4 text-lg text-muted-foreground">Everything you need to know about living at Westholme Park.</p>
    </div>

    <div class="mt-14 space-y-4">
      {faqs.map((faq, i) => (
        <details class="group rounded-xl border border-border bg-card overflow-hidden reveal" style={`transition-delay: ${i * 50}ms`}>
          <summary class="flex cursor-pointer items-center justify-between p-5 text-left font-medium text-card-foreground hover:bg-muted/50 transition-colors">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 shrink-0 text-muted-foreground transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-muted-foreground leading-relaxed">
            {faq.a}
          </div>
        </details>
      ))}
    </div>

    <div class="mt-14 text-center reveal">
      <p class="text-muted-foreground">Still have questions?</p>
      <a href="/contact" class="mt-2 inline-flex items-center text-sm font-semibold text-primary hover:underline">
        Contact us
        <svg class="ml-1 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</Layout>
