---
import Layout from '@/layouts/Layout.astro';
import { ImageLightbox } from '@/components/islands/ImageLightbox';

const images = [
  { src: '/images/hero/hero-1.jpg', alt: 'Property exterior' },
  { src: '/images/rooms/private/bedroom-1.jpg', alt: 'Private bedroom' },
  { src: '/images/rooms/private/bedroom-2.jpg', alt: 'Private bedroom — alternate view' },
  { src: '/images/rooms/private/master-1.jpg', alt: 'Master suite' },
  { src: '/images/rooms/shared/bedroom-1.jpg', alt: 'Shared bedroom' },
  { src: '/images/rooms/shared/bedroom-2.jpg', alt: 'Shared bedroom — alternate view' },
  { src: '/images/common/living.jpg', alt: 'Living room' },
  { src: '/images/common/kitchen.jpg', alt: 'Kitchen' },
  { src: '/images/common/dining.jpg', alt: 'Dining area' },
  { src: '/images/common/bathroom.jpg', alt: 'Bathroom' },
  { src: '/images/common/outdoor.jpg', alt: 'Outdoor patio' },
  { src: '/images/amenities/gym.jpg', alt: 'Fitness area' },
  { src: '/images/amenities/study.jpg', alt: 'Study room' },
  { src: '/images/amenities/laundry.jpg', alt: 'Laundry room' },
  { src: '/images/common/garden.jpg', alt: 'Garden' },
];
---

<Layout title="Gallery — Westholme Park" description="Photos of Westholme Park rooms, common areas, and amenities.">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="max-w-2xl reveal">
      <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">Gallery</h1>
      <p class="mt-4 text-lg text-muted-foreground">Browse photos of our rooms, common spaces, and outdoor areas.</p>
    </div>

    <div class="mt-14 reveal">
      <ImageLightbox client:load images={images} />
    </div>
  </div>
</Layout>
