---
import Layout from '@/layouts/Layout.astro';
import RoomCard from '@/components/astro/RoomCard.astro';

const imageBase = 'https://images.westholmepark.com';
---

<Layout title="Rooms & Pricing — Westholme Park" description="Private rooms, doubles, and dorm rooms for female students near UCLA. Furnished, managed, and move-in ready.">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="max-w-2xl reveal">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Rooms & Pricing</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">Find the room that fits your UCLA routine.</h1>
      <p class="mt-4 text-lg text-muted-foreground">Every room includes furniture, WiFi, utilities, and access to the common spaces. Availability changes by lease cycle, so start with the room style that fits best.</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <RoomCard
        title="Private Room"
        price="From $1,545/mo"
        description="A furnished private room with study space, storage, and natural light for students who want a quieter home base."
        features={['Twin XL bed', 'Desk and chair', 'Closet storage', 'Shared bathroom', 'Common room access']}
        image={`${imageBase}/private-bedroom-bed-desk-window.jpg`}
        badge="Best for privacy"
      />
      <RoomCard
        title="Double Room"
        price="From $1,095/mo"
        description="A furnished two-person room with desks and storage, ideal for students who want value and connection."
        features={['Two desks', 'Individual storage', 'Two-person room', 'Shared bathroom', 'Common room access']}
        image={`${imageBase}/double-study-bedroom-desks.jpg`}
        badge="Best value"
      />
      <RoomCard
        title="Dorm Room"
        price="From $995/mo"
        description="A social dorm-style room with built-in bunks, privacy curtains, wardrobes, and study stations."
        features={['Built-in bunks', 'Privacy curtains', 'Wardrobes', 'Study desks', 'Shared bathroom']}
        image={`${imageBase}/shared-pod-bunk-room-wide.jpg`}
        badge="Limited"
      />
    </div>

    <div class="mt-16 grid gap-8 rounded-lg border border-border bg-muted/30 p-8 sm:p-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center reveal">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Interactive floor plan</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-foreground">Compare room locations before you tour.</h2>
        <p class="mt-4 text-muted-foreground">
          Explore Floor 1 to see room positions, nearby bathrooms, and the shared spaces that shape daily life in the house.
        </p>
        <a
          href="/floor-plans"
          class="mt-6 inline-flex items-center justify-center rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground transition-opacity hover:opacity-90"
        >
          View Floor Plans
        </a>
      </div>
      <div class="overflow-hidden rounded-lg border border-border bg-background">
        <img
          src="/floor-plans/floor-1.jpg"
          alt="Westholme Park first floor plan preview"
          class="h-80 w-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>

    <div class="mt-16 rounded-lg border border-border bg-muted/30 p-8 sm:p-10 reveal">
      <h2 class="text-xl font-semibold text-foreground">Included in every room</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          'All utilities (electric, gas, water)',
          'Gigabit fiber WiFi',
          'Fully furnished',
          'On-site laundry access',
          'Weekly housekeeping of common areas',
          'Secure keyless entry',
          'Outdoor parking available',
          '24/7 maintenance support',
          'Shared kitchen and living spaces',
        ].map((item) => (
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <svg class="h-4 w-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
