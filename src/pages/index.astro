---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/astro/HeroSection.astro';
import RoomCard from '@/components/astro/RoomCard.astro';
import AmenityGrid from '@/components/astro/AmenityGrid.astro';
import GalleryTeaser from '@/components/astro/GalleryTeaser.astro';
import ContactCTA from '@/components/astro/ContactCTA.astro';

const imageBase = 'https://images.westholmepark.com';
---

<Layout>
  <HeroSection />

  <section class="border-b border-border bg-background">
    <div class="mx-auto grid max-w-7xl gap-4 px-4 py-8 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      {[
        ['Walkable', 'Minutes from UCLA and Westwood routines'],
        ['Furnished', 'Beds, desks, storage, and shared spaces ready'],
        ['Managed', 'A local team for tours, move-in, and support'],
        ['All-in', 'Utilities, WiFi, and essentials simplified'],
      ].map(([title, desc]) => (
        <div class="border-l border-border pl-4">
          <p class="text-sm font-semibold text-foreground">{title}</p>
          <p class="mt-1 text-sm text-muted-foreground">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-center lg:px-8">
    <div class="reveal">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Less apartment stress</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">More time for the UCLA life you came for.</h2>
      <p class="mt-5 text-lg leading-8 text-muted-foreground">
        Westholme Park is designed for students who want independence without having to assemble an apartment from scratch. Move into a furnished room, settle into a beautiful shared home, and keep your energy for classes, friendships, and Westwood.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {[
          ['For students', 'A real home base with privacy, study space, and community close to campus.'],
          ['For families', 'A managed, furnished property with clearer logistics and fewer move-in surprises.'],
        ].map(([title, desc]) => (
          <div class="border border-border bg-card p-5">
            <h3 class="font-semibold text-card-foreground">{title}</h3>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">{desc}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="grid gap-3 reveal">
      <img
        src={`${imageBase}/dining-room-study-tables.jpg`}
        alt="Westholme Park dining and study room"
        class="aspect-[16/10] w-full object-cover"
        loading="lazy"
      />
      <div class="grid gap-3 sm:grid-cols-2">
        <img
          src={`${imageBase}/private-bedroom-twin-desk-wide.jpg`}
          alt="Private bedroom with twin bed and desk"
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
        />
        <img
          src={`${imageBase}/courtyard-cafe-tables.jpg`}
          alt="Courtyard cafe tables"
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto reveal">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Choose your fit</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Rooms that make move-in simple</h2>
      <p class="mt-4 text-lg text-muted-foreground">Private rooms, doubles, and dorm rooms with furniture, storage, and practical study space already in place.</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <RoomCard
        title="Private Room"
        price="From $1,545/mo"
        description="A calm, furnished room for privacy, focus, and a daily routine that feels your own."
        features={['Twin XL bed', 'Desk and chair', 'Closet storage', 'Natural light']}
        image={`${imageBase}/private-bedroom-bed-desk-window.jpg`}
        badge="Best for privacy"
      />
      <RoomCard
        title="Double Room"
        price="From $1,095/mo"
        description="A furnished two-person room with desks, storage, and a more affordable way to live close to UCLA."
        features={['Two desks', 'Individual storage', 'Two-person room', 'Community feel']}
        image={`${imageBase}/double-study-bedroom-desks.jpg`}
        badge="Best value"
      />
      <RoomCard
        title="Dorm Room"
        price="From $995/mo"
        description="A social dorm-style room with built-in bunks, privacy curtains, wardrobes, and study desks."
        features={['Built-in bunks', 'Privacy curtains', 'Wardrobes', 'Study desks']}
        image={`${imageBase}/shared-pod-bunk-room-wide.jpg`}
        badge="Limited"
      />
    </div>
  </section>

  <AmenityGrid />

  <section class="bg-foreground text-background">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:px-8">
      <div class="reveal">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-background/70">The feeling</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">A student house that still feels grown up.</h2>
        <p class="mt-5 text-lg leading-8 text-background/75">
          Historic details, warm common rooms, outdoor tables, and furnished bedrooms give Westholme Park a sense of place that typical student housing rarely has.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-3 reveal">
        <img src={`${imageBase}/entry-lobby-staircase.jpg`} alt="Entry lobby staircase" class="aspect-[4/3] w-full object-cover" loading="lazy" />
        <img src={`${imageBase}/courtyard-cafe-tables.jpg`} alt="Courtyard cafe tables" class="aspect-[4/3] w-full object-cover" loading="lazy" />
        <img src={`${imageBase}/dining-room-study-tables.jpg`} alt="Dining room with study tables" class="col-span-2 aspect-[16/9] w-full object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <GalleryTeaser />
  <ContactCTA />
</Layout>
