---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Contact — Westholme Park" description="Get in touch with Westholme Park. Apply online, schedule a tour, or send us an email.">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="max-w-2xl reveal">
      <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">Contact Us</h1>
      <p class="mt-4 text-lg text-muted-foreground">Ready to apply or just have questions? We'd love to hear from you.</p>
    </div>

    <div class="mt-14 grid gap-8 lg:grid-cols-2">
      <div class="space-y-6 reveal">
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="font-semibold text-card-foreground">Apply Online</h3>
          <p class="mt-2 text-sm text-muted-foreground">Submit your application in just a few minutes through our online form.</p>
          <a
            href="https://tally.so/r/mV86WJ"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center justify-center rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity"
          >
            Start Application
          </a>
        </div>

        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="font-semibold text-card-foreground">Schedule a Tour</h3>
          <p class="mt-2 text-sm text-muted-foreground">Book a virtual or in-person tour to see the property and available rooms.</p>
          <a
            href="https://cal.affinity.house/team/wp/cn-tour"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center justify-center rounded-lg border border-border bg-background px-5 py-2.5 text-sm font-semibold text-foreground hover:bg-muted transition-colors"
          >
            Book a Tour
          </a>
        </div>

        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="font-semibold text-card-foreground">Email Us</h3>
          <p class="mt-2 text-sm text-muted-foreground">For general questions, reach out anytime.</p>
          <a
            href="mailto:join@westholmepark.com"
            class="mt-4 inline-flex items-center text-sm font-semibold text-primary hover:underline"
          >
            join@westholmepark.com
          </a>
        </div>
      </div>

      <div class="reveal">
        <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-border bg-muted">
          <img
            src="/images/common/outdoor.jpg"
            alt="Westholme Park outdoor area"
            class="h-full w-full object-cover"
            onerror="this.parentElement.classList.add('flex','items-center','justify-center');this.outerHTML='<span class=text-muted-foreground>Photo coming soon</span>'"
          />
        </div>
        <div class="mt-6 rounded-xl border border-border bg-muted p-6">
          <h3 class="font-semibold text-foreground">Office Hours</h3>
          <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
            <li class="flex justify-between"><span>Monday – Friday</span> <span>9:00 AM – 6:00 PM</span></li>
            <li class="flex justify-between"><span>Saturday</span> <span>10:00 AM – 4:00 PM</span></li>
            <li class="flex justify-between"><span>Sunday</span> <span>By appointment</span></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>
