---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Page Not Found — Westholme Park">
  <div class="mx-auto max-w-7xl px-4 py-32 text-center sm:px-6 lg:px-8">
    <h1 class="text-6xl font-bold tracking-tight text-foreground">404</h1>
    <p class="mt-4 text-lg text-muted-foreground">This page doesn't exist.</p>
    <a href="/" class="mt-8 inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity">
      Go Home
    </a>
  </div>
</Layout>
