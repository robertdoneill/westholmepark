---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<Layout title={`${title} — Westholme Park Docs`} description={description}>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <aside class="lg:w-64 shrink-0">
        <nav class="sticky top-24 space-y-1">
          <p class="px-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-2">Documentation</p>
          <a href="/docs/getting-started/" class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${Astro.url.pathname.startsWith('/docs/getting-started') ? 'text-foreground bg-muted' : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'}`}>Getting Started</a>
          <a href="/docs/moving-out/" class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${Astro.url.pathname.startsWith('/docs/moving-out') ? 'text-foreground bg-muted' : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'}`}>Moving Out</a>
          <a href="/docs/what-to-bring/" class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${Astro.url.pathname.startsWith('/docs/what-to-bring') ? 'text-foreground bg-muted' : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'}`}>What to Bring</a>
        </nav>
      </aside>

      <article class="flex-1 min-w-0 max-w-3xl">
        <div class="prose prose-zinc dark:prose-invert max-w-none">
          <h1 class="text-3xl font-bold tracking-tight text-foreground">{title}</h1>
          {description && <p class="mt-2 text-lg text-muted-foreground">{description}</p>}
          <div class="mt-8">
            <slot />
          </div>
        </div>
      </article>
    </div>
  </div>
</Layout>
